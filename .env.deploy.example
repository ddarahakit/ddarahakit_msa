# ============================================================================
#  배포 서버 .env 템플릿  (docker-compose.deploy.yml 용)
#  대상 서버에서 이 파일을 .env 로 복사하고 실제 값으로 채운다.  →  cp .env.deploy.example .env
#  ※ 실제 .env 는 절대 git/이미지/공개 저장소에 올리지 말 것.
# ============================================================================

# ---- GHCR 이미지 좌표 ----
GHCR_OWNER=ddarahakit
IMAGE_TAG=1.0.0

# ---- DB (mariadb) ----
DB_ROOT_PASSWORD=change-me-strong-root-pw
DB_USER=ddarahakit
DB_PASSWORD=change-me-strong-db-pw

# ---- 보안 키 ----
JWT_SECRET=base64-encoded-256bit-secret        # 게이트웨이/identity 공통(동일 값)
AES_SECRET_KEY=exactly-32-characters-aes256-key # 정확히 32자 (AES-256)

# ---- 공개 접속 주소(브라우저 기준) ----
# 프론트가 호출하는 게이트웨이 공개 출처. 프론트 이미지 빌드 시 넣은 VITE_API_BASE_URL 과 "정확히 동일" 해야 한다.
ALLOWED_ORIGINS=http://YOUR_SERVER:8081           # 프론트가 떠 있는 출처(브라우저 Origin)

# ---- 인증 쿠키/도메인 (다른 서버에선 반드시 맞춰 주입) ----
# localhost 기본값을 그대로 쓰면 다른 서버에서 쿠키가 거부되어 로그인 유지가 안 된다.
APP_DOMAIN_SERVER=http://YOUR_SERVER:8080         # OAuth 리다이렉트/메일 링크 베이스
APP_DOMAIN_COOKIE=YOUR_SERVER                     # 쿠키 도메인(IP 면 비워도 됨)
# IP 로 접속(HTTP) 하는 경우 — Domain 생략(host-only):
APP_TOKEN_ACCESS_FORMAT=ATOKEN=%s; HttpOnly; SameSite=Lax; Path=/; Max-Age=%d
APP_TOKEN_REFRESH_FORMAT=RTOKEN=%s; HttpOnly; SameSite=Lax; Path=/; Max-Age=%d
# 도메인+HTTPS 인 경우 예시(위 두 줄 대신):
# APP_TOKEN_ACCESS_FORMAT=ATOKEN=%s; HttpOnly; Secure; SameSite=Lax; Domain=example.com; Path=/; Max-Age=%d
# APP_TOKEN_REFRESH_FORMAT=RTOKEN=%s; HttpOnly; Secure; SameSite=Lax; Domain=example.com; Path=/; Max-Age=%d

# ---- 메일(비밀번호 재설정/이메일 인증) ----
MAIL_ADDR=your@gmail.com
MAIL_PASSWORD=gmail-app-password

# ---- OAuth ----
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://YOUR_SERVER:8080/login/oauth2/code/google
KAKAO_CLIENT_ID=...
KAKAO_CLIENT_SECRET=...
KAKAO_REDIRECT_URI=http://YOUR_SERVER:8080/login/oauth2/code/kakao

# ---- 결제(PortOne) ----
PORTONE_SECRET=...
